-- Character Handling Utilities
local function restorePart(char, partName)
    local part = char:FindFirstChild(partName)
    if part and originalSizes[char.Name .. partName] then
        part.Size = originalSizes[char.Name .. partName]
        part.Transparency = originalSizes[char.Name .. partName .. "_Trans"] or 0
        part.Massless = false
    end
end

local function updateESP(char)
    local head = char:FindFirstChild("Head")
    if config.ESPEnabled and head then
        -- Chams / Highlight management
        local hl = char:FindFirstChild("JanHighlight")
        if not hl then 
            hl = Instance.new("Highlight")
            hl.Name = "JanHighlight"
            hl.Parent = char
        end
        hl.FillTransparency = config.ESPTransparency
        hl.OutlineTransparency = config.ESPTransparency
        
        -- Screen-spaced Billboard placement
        local bill = head:FindFirstChild("ESP_UI")
        if not bill then
            bill = Instance.new("BillboardGui")
            bill.Name = "ESP_UI"
            bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0, 140, 0, 30)
            bill.StudsOffset = Vector3.new(0, 2.5, 0)
            bill.Parent = head
            
            local lbl = Instance.new("TextLabel")
            lbl.Name = "InfoLabel"
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.new(1, 1, 1)
            lbl.TextSize = 13
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextStrokeTransparency = 0
            lbl.Parent = bill
        end
        
        local hum = char:FindFirstChild("Humanoid")
        local status = (hum and hum.Health > 0) and math.floor(hum.Health) .. " HP" or "DEAD"
        bill.InfoLabel.Text = char.Name .. " [" .. status .. "]"
    else
        if char:FindFirstChild("JanHighlight") then char.JanHighlight:Destroy() end
        if head and head:FindFirstChild("ESP_UI") then head.ESP_UI:Destroy() end
    end
end

-- Process Dynamic Hitbox Adjustment for a Model
local function handleHitboxProcessing(c, isNPC, playerObj)
    local isEnabled = isNPC and config.NPCHitboxEnabled or config.HitboxEnabled
    local targetPart = isNPC and config.NPCTargetPart or config.TargetPart
    local hitboxSize = isNPC and config.NPCHitboxSize or config.HitboxSize
    local hitboxTrans = isNPC and config.NPCHitboxTransparency or config.HitboxTransparency
    
    local target = c:FindFirstChild(targetPart)
    local other = (targetPart == "Head") and "UpperTorso" or "Head"
    
    local passesTeamCheck = true
    if not isNPC and playerObj and config.TeamCheck and playerObj.Team == LocalPlayer.Team then
        passesTeamCheck = false
    end
    
    if isEnabled and passesTeamCheck and target then
        if not originalSizes[c.Name .. targetPart] then 
            originalSizes[c.Name .. targetPart] = target.Size 
            originalSizes[c.Name .. targetPart .. "_Trans"] = target.Transparency
        end
        restorePart(c, other)
        
        target.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
        target.Transparency = hitboxTrans
        target.Massless = true
        target.CanCollide = false
    else
        restorePart(c, "Head")
        restorePart(c, "UpperTorso")
    end
end

