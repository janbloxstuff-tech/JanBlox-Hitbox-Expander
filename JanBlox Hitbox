local flyRenderConn
local flyBodyGyro, flyBodyVelocity
local lastDirection = Vector3.new(0, 0, 0) -- Stores the persistent lock direction

local function stopFlying(char)
	if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
	if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
	if flyRenderConn then flyRenderConn:Disconnect(); flyRenderConn = nil end
	lastDirection = Vector3.new(0, 0, 0) -- Reset direction cache
	
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.PlatformStand = false
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)
	end
end

local function startFlying(char)
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end
	
	stopFlying(char)
	task.wait(0.05)
	hum.PlatformStand = true
	
	flyBodyGyro = Instance.new("BodyGyro")
	flyBodyGyro.P = 9e4
	flyBodyGyro.maxTorque = Vector3.new(9e5, 9e5, 9e5)
	flyBodyGyro.cframe = root.CFrame
	flyBodyGyro.Parent = root
	
	flyBodyVelocity = Instance.new("BodyVelocity")
	flyBodyVelocity.velocity = Vector3.new(0, 0, 0)
	flyBodyVelocity.maxForce = Vector3.new(9e5, 9e5, 9e5)
	flyBodyVelocity.Parent = root
	
	local camera = workspace.CurrentCamera
	
	-- Fetch the player module once for mobile joystick tracking
	local playerScripts = LocalPlayer:WaitForChild("PlayerScripts")
	local playerModule = playerScripts:FindFirstChild("PlayerModule")
	local controls = playerModule and require(playerModule):GetControls()
	
	flyRenderConn = RunService.RenderStepped:Connect(function()
		if not char.Parent or not hum or hum.Health <= 0 or not config.FlyEnabled then
			stopFlying(char)
			return
		end
		
		flyBodyGyro.cframe = camera.CFrame
		local currentInputDirection = Vector3.new(0, 0, 0)
		
		-- 1. PC Directional Keys input check
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then currentInputDirection += camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then currentInputDirection -= camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then currentInputDirection -= camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then currentInputDirection += camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then currentInputDirection += Vector3.new(0, 1, 0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then currentInputDirection -= Vector3.new(0, 1, 0) end
		
		-- 2. Mobile Joystick input check
		if controls then
			local moveVector = controls:GetMoveVector()
			if moveVector.Magnitude > 0 then
				local camLook = camera.CFrame.LookVector
				local camRight = camera.CFrame.RightVector
				currentInputDirection += (camLook * -moveVector.Z) + (camRight * moveVector.X)
			end
		end
		
		-- If there is active user input (tap/press), update the persistent flight path
		if currentInputDirection.Magnitude > 0 then
			lastDirection = currentInputDirection.Unit
		end
		
		-- Continually applies velocity using the saved direction without requiring a hold action
		if config.FlyEnabled and lastDirection.Magnitude > 0 then
			-- Dynamic lock: Updates flight vector to follow camera adjustments even when letting go of controls
			if currentInputDirection.Magnitude == 0 then
				flyBodyVelocity.velocity = camera.CFrame.LookVector * config.FlySpeed
			else
				flyBodyVelocity.velocity = lastDirection * config.FlySpeed
			end
		else
			flyBodyVelocity.velocity = Vector3.new(0, 0.05, 0)
		end
	end)
end

