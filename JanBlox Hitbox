-- Optimized cache system for localized NPC updates
local cachedNPCs = {}
local function updateNPCCache()
    local currentNPCs = {}
    for _, desc in pairs(workspace:GetDescendants()) do
        if desc:IsA("Humanoid") then
            local model = desc.Parent
            if model and model:IsA("Model") and model ~= LocalPlayer.Character and not Players:GetPlayerFromCharacter(model) then
                table.insert(currentNPCs, model)
            end
        end
    end
    cachedNPCs = currentNPCs
end

task.spawn(function()
    while true do
        updateNPCCache()
        task.wait(3)
    end
end)

-- Main Run Engine Loops
RunService.Heartbeat:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        updateESP(p.Character, p)
        handlePlayerHitbox(p.Character, p)
    end
    
    for i = 1, #cachedNPCs do
        local npc = cachedNPCs[i]
        if npc and npc.Parent then
            handleNPCHitbox(npc)
        end
    end
end)

