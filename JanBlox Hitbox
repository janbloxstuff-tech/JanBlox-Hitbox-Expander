local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Configuration
local config = {
    HitboxEnabled = false, TeamCheck = false, ESPEnabled = false,
    TargetPart = "Head", HitboxSize = 5, WS = 16, JP = 50
}
local originalSizes = {}

-- Setup UI
local screenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
screenGui.Name = "JanBloxGui"
screenGui.ResetOnSpawn = false

local scrollFrame = Instance.new("ScrollingFrame", screenGui)
scrollFrame.Size = UDim2.new(0, 260, 0, 400)
scrollFrame.Position = UDim2.new(0.1, 0, 0.1, 0)
scrollFrame.CanvasSize = UDim2.new(0, 0, 2, 0)
scrollFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)

local layout = Instance.new("UIListLayout", scrollFrame)
layout.Padding = UDim.new(0, 5)
layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

local function addTitle(text)
    local t = Instance.new("TextLabel", scrollFrame)
    t.Size = UDim2.new(0.95, 0, 0, 30); t.Text = text; t.TextColor3 = Color3.new(1, 1, 1)
    t.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
end

local function addBtn(text)
    local btn = Instance.new("TextButton", scrollFrame)
    btn.Size = UDim2.new(0.95, 0, 0, 35); btn.Text = text
    return btn
end

-- Create GUI Layout
addTitle("JanBlox Gui")
local hitBtn = addBtn("Hitbox: OFF")
local teamBtn = addBtn("Team Check: OFF")
local swapBtn = addBtn("Target: Head")

local sizeFrame = Instance.new("Frame", scrollFrame); sizeFrame.Size = UDim2.new(0.95, 0, 0, 35); sizeFrame.BackgroundTransparency = 1
local upBtn = Instance.new("TextButton", sizeFrame); upBtn.Size = UDim2.new(0.48, 0, 1, 0); upBtn.Text = "+ Size"
local downBtn = Instance.new("TextButton", sizeFrame); downBtn.Size = UDim2.new(0.48, 0, 1, 0); downBtn.Position = UDim2.new(0.52, 0, 0, 0); downBtn.Text = "- Size"

addTitle("ESP Configuration")
local espBtn = addBtn("ESP: OFF")

addTitle("Player Configuration")
local wsBtn = addBtn("WS: 16")
local jpBtn = addBtn("JP: 50")
local resetBtn = addBtn("Reset WS/JP")

-- Logic Functions
local function restorePart(char, partName)
    local part = char:FindFirstChild(partName)
    if part and originalSizes[char.Name .. partName] then
        part.Size = originalSizes[char.Name .. partName]
        part.Massless = false
    end
end

local function updateESP(char)
    local head = char:FindFirstChild("Head")
    if config.ESPEnabled and head then
        if not char:FindFirstChild("Highlight") then Instance.new("Highlight", char) end
        if not head:FindFirstChild("ESP_UI") then
            local bill = Instance.new("BillboardGui", head); bill.Name = "ESP_UI"; bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0, 100, 0, 50); bill.StudsOffset = Vector3.new(0, 3, 0)
            Instance.new("TextLabel", bill).Size = UDim2.new(1,0,1,0).BackgroundTransparency = 1
        end
        local hum = char:FindFirstChild("Humanoid")
        local status = (hum and hum.Health > 0) and math.floor(hum.Health) .. " HP" or "DEAD"
        head.ESP_UI.TextLabel.Text = char.Name .. "\n" .. status
    else
        if char:FindFirstChild("Highlight") then char.Highlight:Destroy() end
        if head and head:FindFirstChild("ESP_UI") then head.ESP_UI:Destroy() end
    end
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer or not p.Character then continue end
        local c = p.Character
        updateESP(c)

        local target = c:FindFirstChild(config.TargetPart)
        local other = (config.TargetPart == "Head") and "UpperTorso" or "Head"
        
        if config.HitboxEnabled and (not config.TeamCheck or p.Team ~= LocalPlayer.Team) and target then
            if not originalSizes[c.Name .. config.TargetPart] then originalSizes[c.Name .. config.TargetPart] = target.Size end
            restorePart(c, other) -- Reset non-target
            target.Size = Vector3.new(config.HitboxSize, config.HitboxSize, config.HitboxSize)
            target.Massless = true
            target.CanCollide = false
        else
            restorePart(c, "Head"); restorePart(c, "UpperTorso")
        end
    end
    
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = config.WS
        LocalPlayer.Character.Humanoid.JumpPower = config.JP
    end
end)

-- Buttons
hitBtn.MouseButton1Click:Connect(function() config.HitboxEnabled = not config.HitboxEnabled; hitBtn.Text = "Hitbox: " .. (config.HitboxEnabled and "ON" or "OFF") end)
teamBtn.MouseButton1Click:Connect(function() config.TeamCheck = not config.TeamCheck; teamBtn.Text = "Team Check: " .. (config.TeamCheck and "ON" or "OFF") end)
espBtn.MouseButton1Click:Connect(function() config.ESPEnabled = not config.ESPEnabled; espBtn.Text = "ESP: " .. (config.ESPEnabled and "ON" or "OFF") end)
swapBtn.MouseButton1Click:Connect(function() config.TargetPart = (config.TargetPart == "Head") and "UpperTorso" or "Head"; swapBtn.Text = "Target: " .. config.TargetPart end)
upBtn.MouseButton1Click:Connect(function() config.HitboxSize += 5 end)
downBtn.MouseButton1Click:Connect(function() config.HitboxSize = math.max(1, config.HitboxSize - 5) end)
wsBtn.MouseButton1Click:Connect(function() config.WS += 5; wsBtn.Text = "WS: " .. config.WS end)
jpBtn.MouseButton1Click:Connect(function() config.JP += 5; jpBtn.Text = "JP: " .. config.JP end)
resetBtn.MouseButton1Click:Connect(function() config.WS = 16; config.JP = 50; wsBtn.Text = "WS: 16"; jpBtn.Text = "JP: 50" end)
