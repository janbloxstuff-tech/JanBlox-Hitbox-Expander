-- Runs every step frame to instantly match requirements and secure continuous hitbox mapping
RunService.RenderStepped:Connect(function()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			updateESP(p.Character, p)
			handlePlayerHitbox(p.Character, p)
		end
	end

	for i = #cachedNPCs, 1, -1 do
		local npc = cachedNPCs[i]
		if npc and npc.Parent then
			handleNPCHitbox(npc)
		else
			table.remove(cachedNPCs, i)
		end
	end

	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")

	if hum then
		if config.BypassWalkspeedJump then
			if hum.WalkSpeed ~= config.WS then
				hum.WalkSpeed = config.WS
			end
			if hum.JumpPower ~= config.JP then
				hum.JumpPower = config.JP
			end
			if config.AutoJump and hum.MoveDirection.Magnitude > 0 then
				hum.Jump = true
			end
		end
	end
end)

