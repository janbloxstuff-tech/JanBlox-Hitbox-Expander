-- Character Handling Utilities
local function restorePart(char, partName, storage)
    local part = char:FindFirstChild(partName)
    if part and storage[char] and storage[char][partName] then
        part.Size = storage[char][partName].Size
        part.Transparency = storage[char][partName].Transparency
        part.CanCollide = storage[char][partName].CanCollide
        part.CanTouch = storage[char][partName].CanTouch
        part.CanQuery = storage[char][partName].CanQuery
        part.CastShadow = storage[char][partName].CastShadow
        part.Massless = false
    end
end

-- Clean up helper to erase active ESP modules instantly
local function removeESP(char)
    if char:FindFirstChild("JanHighlight") then char.JanHighlight:Destroy() end
    local head = char:FindFirstChild("Head")
    if head and head:FindFirstChild("ESP_UI") then head.ESP_UI:Destroy() end
end

local function updateESP(char, playerObj)
    local head = char:FindFirstChild("Head")
    
    -- ENEMY ONLY / TEAM CHECK LOGIC
    local passesESPTeamCheck = not (config.TeamCheck and playerObj and playerObj.Team == LocalPlayer.Team)
    
    if config.ESPEnabled and passesESPTeamCheck and head then
        local hl = char:FindFirstChild("JanHighlight")
        if not hl then 
            hl = Instance.new("Highlight")
            hl.Name = "JanHighlight"
            hl.Parent = char
        end
        hl.FillTransparency = config.ESPTransparency
        hl.OutlineTransparency = config.ESPTransparency
        
        local bill = head:FindFirstChild("ESP_UI")
        if not bill then
            bill = Instance.new("BillboardGui")
            bill.Name = "ESP_UI"
            bill.AlwaysOnTop = true
            bill.Size = UDim2.new(0, 140, 0, 30)
            bill.StudsOffset = Vector3.new(0, 2.5, 0)
            bill.Parent = head
            
            local lbl = Instance.new("TextLabel")
            lbl.Name = "InfoLabel"
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3 = Color3.new(1, 1, 1)
            lbl.TextSize = 13
            lbl.Font = Enum.Font.SourceSansBold
            lbl.TextStrokeTransparency = 0
            lbl.Parent = bill
        end
        
        local hum = char:FindFirstChild("Humanoid")
        local status = (hum and hum.Health > 0) and math.floor(hum.Health) .. " HP" or "DEAD"
        bill.InfoLabel.Text = char.Name .. " [" .. status .. "]"
    else
        removeESP(char)
    end
end

-- Completely Isolated Player Hitbox Logic (Damage Registered + Smooth Performance)
local function handlePlayerHitbox(c, playerObj)
    local targetPart = config.TargetPart
    local target = c:FindFirstChild(targetPart)
    
    if not target and targetPart == "UpperTorso" then
        target = c:FindFirstChild("Torso") or c:FindFirstChild("LowerTorso")
    end
    
    local other = (targetPart == "Head") and "UpperTorso" or "Head"
    local passesTeamCheck = not (config.TeamCheck and playerObj.Team == LocalPlayer.Team)
    
    if config.HitboxEnabled and passesTeamCheck and target then
        if not originalPlayerSizes[c] then originalPlayerSizes[c] = {} end
        if not originalPlayerSizes[c][target.Name] then
            originalPlayerSizes[c][target.Name] = {
                Size = target.Size, 
                Transparency = target.Transparency,
                CanCollide = target.CanCollide,
                CanTouch = target.CanTouch,
                CanQuery = target.CanQuery,
                CastShadow = target.CastShadow
            }
        end
        
        restorePart(c, other, originalPlayerSizes)
        restorePart(c, "Torso", originalPlayerSizes)
        restorePart(c, "LowerTorso", originalPlayerSizes)
        
        target.Size = Vector3.new(config.HitboxSize, config.HitboxSize, config.HitboxSize)
        target.Transparency = config.HitboxTransparency
        target.Massless = true
        target.CanCollide = false
        target.CastShadow = false -- Eliminates massive map lighting frame drops
        
        -- ESSENTIAL FOR HIT/DAMAGE REGISTRATION:
        target.CanTouch = true    
        target.CanQuery = true    
    else
        restorePart(c, "Head", originalPlayerSizes)
        restorePart(c, "UpperTorso", originalPlayerSizes)
        restorePart(c, "Torso", originalPlayerSizes)
        restorePart(c, "LowerTorso", originalPlayerSizes)
    end
end

