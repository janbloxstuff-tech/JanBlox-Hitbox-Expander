local function toggleMenuVisuals()
	if menuMoving then return end
	menuMoving = true

	if mainFrame.Visible then
		local closeTween = TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			Size = UDim2.new(0, originalSize.X.Offset, 0, 0),
			BackgroundTransparency = 1
		})
		TweenService:Create(mainHeaderTitle, TweenInfo.new(0.15), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
		TweenService:Create(headerFlattener, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
		scrollFrame.Visible = false
		closeTween:Play()
		closeTween.Completed:Connect(function()
			mainFrame.Visible = false
			updateMouseLock()
			menuMoving = false
		end)
	else
		mainFrame.Size = UDim2.new(0, originalSize.X.Offset, 0, 0)
		mainFrame.BackgroundTransparency = 1
		mainHeaderTitle.TextTransparency = 1
		mainHeaderTitle.BackgroundTransparency = 1
		headerFlattener.BackgroundTransparency = 1
		mainFrame.Visible = true
		updateMouseLock()

		local openTween = TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Size = originalSize,
			BackgroundTransparency = 0
		})
		TweenService:Create(mainHeaderTitle, TweenInfo.new(0.25), {TextTransparency = 0, BackgroundTransparency = 0}):Play()
		TweenService:Create(headerFlattener, TweenInfo.new(0.25), {BackgroundTransparency = 0}):Play()
		openTween:Play()
		openTween.Completed:Connect(function()
			scrollFrame.Visible = true
			menuMoving = false
		end)
	end
end

