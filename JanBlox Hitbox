local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local guiEnabled = false
local headSizeValue = 50
local targetBodyPart = "Head" -- Toggle between "Head" and "UpperTorso"

-- UI Setup
local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
screenGui.Name = "JanBloxGui"
screenGui.ResetOnSpawn = false

local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 220, 0, 200)
frame.Position = UDim2.new(0.1, 0, 0.1, 0)
frame.Active = true
frame.Draggable = true

local toggleBtn = Instance.new("TextButton", frame)
toggleBtn.Size = UDim2.new(0, 200, 0, 40)
toggleBtn.Position = UDim2.new(0.05, 0, 0.05, 0)
toggleBtn.Text = "Hitbox Expander: OFF"

local swapBtn = Instance.new("TextButton", frame)
swapBtn.Size = UDim2.new(0, 200, 0, 40)
swapBtn.Position = UDim2.new(0.05, 0, 0.3, 0)
swapBtn.Text = "Target: Head"

local upBtn = Instance.new("TextButton", frame)
upBtn.Size = UDim2.new(0, 95, 0, 40)
upBtn.Position = UDim2.new(0.05, 0, 0.55, 0)
upBtn.Text = "+ Size"

local downBtn = Instance.new("TextButton", frame)
downBtn.Size = UDim2.new(0, 95, 0, 40)
downBtn.Position = UDim2.new(0.5, 0, 0.55, 0)
downBtn.Text = "- Size"

-- Logic
local function modifyPart(char)
	if not guiEnabled then return end
	-- Target specific part, ignore own character
	if char == player.Character then return end
	
	local part = char:FindFirstChild(targetBodyPart)
	if part and part:IsA("BasePart") then
		part.Size = Vector3.new(headSizeValue, headSizeValue, headSizeValue)
		part.Massless = true
		part.CanCollide = false
	end
end

toggleBtn.MouseButton1Click:Connect(function()
	guiEnabled = not guiEnabled
	toggleBtn.Text = guiEnabled and "Hitbox Expander: ON" or "Hitbox Expander: OFF"
end)

swapBtn.MouseButton1Click:Connect(function()
	targetBodyPart = (targetBodyPart == "Head") and "UpperTorso" or "Head"
	swapBtn.Text = "Target: " .. targetBodyPart
end)

upBtn.MouseButton1Click:Connect(function() headSizeValue += 5 end)
downBtn.MouseButton1Click:Connect(function() headSizeValue = math.max(1, headSizeValue - 5) end)

-- Loop to apply changes consistently without bugging out
RunService.RenderStepped:Connect(function()
	if guiEnabled then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				modifyPart(p.Character)
			end
		end
	end
end)

