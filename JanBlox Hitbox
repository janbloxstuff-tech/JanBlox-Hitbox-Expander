	refreshAllPlayers()
end)

wsBtn.MouseButton1Click:Connect(function()
	config.WS = (config.WS >= 100) and 16 or (config.WS + 10)
	wsBtn.Text = "WS: " .. config.WS
end)

jpBtn.MouseButton1Click:Connect(function()
	config.JP = (config.JP >= 200) and 50 or (config.JP + 15)
	jpBtn.Text = "JP: " .. config.JP
end)

globalHitboxBtn.MouseButton1Click:Connect(function()
	config.GlobalHitboxToggle = not config.GlobalHitboxToggle
	globalHitboxBtn.Text = "Toggle Hitboxes: " .. (config.GlobalHitboxToggle and "ON" or "OFF")
	refreshAllPlayers()
	refreshAllNPCs()
end)

autoJumpBtn.MouseButton1Click:Connect(function()
	config.AutoJump = not config.AutoJump
