local function savePartState(char, part, storage)
	if not storage[char] then
		storage[char] = {}
	end

	if not storage[char][part.Name] then
		storage[char][part.Name] = {
			Size = part.Size,
			Transparency = part.Transparency,
			CanCollide = part.CanCollide,
			CanTouch = part.CanTouch,
			CanQuery = part.CanQuery,
			Massless = part.Massless
		}
	end
end

local function restorePart(char, partName, storage)
	local charStorage = storage[char]
	if not charStorage then
		return
	end

	local data = charStorage[partName]
	if not data then
		return
	end

	local part = char:FindFirstChild(partName)
	if not part then
		return
	end

	part.Size = data.Size
	part.Transparency = data.Transparency
	part.CanCollide = data.CanCollide
	part.CanTouch = data.CanTouch
	part.CanQuery = data.CanQuery
	part.Massless = data.Massless
end

local function restoreAllCandidateParts(char, storage)
	for _, partName in ipairs(candidateParts) do
		restorePart(char, partName, storage)
	end
end

local function isAliveCharacter(char)
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	return hum ~= nil and hum.Health > 0 and hum:GetState() ~= Enum.HumanoidStateType.Dead
end

local function destroyESP(char)
	local hl = char:FindFirstChild("ESPHighlight")
	if hl then
		hl:Destroy()
	end

	local head = char:FindFirstChild("Head")
	if head then
		local bill = head:FindFirstChild("ESP_UI")
		if bill then
			bill:Destroy()
		end
	end
end

local function updateESP(char, playerObj)
	local hum = char:FindFirstChildOfClass("Humanoid")

	if not isAliveCharacter(char) then
		destroyESP(char)
		if hum then
			hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer
		end
		return
	end

	local showESP = config.ESPEnabled and (not config.TeamCheck or playerObj.Team ~= LocalPlayer.Team)

	if not showESP then
		destroyESP(char)
		if hum then
			hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer
		end
		return
	end

	if hum then
		hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	end

	local head = char:FindFirstChild("Head")
	if not head then
		return
	end

	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Highlight") and child.Name ~= "ESPHighlight" then
			child:Destroy()
		end
	end

	local hl = char:FindFirstChild("ESPHighlight")
	if not hl then
		hl = Instance.new("Highlight")
		hl.Name = "ESPHighlight"
		hl.Parent = char
	end

	hl.FillTransparency = config.ESPTransparency
	hl.OutlineTransparency = config.ESPTransparency

	local bill = head:FindFirstChild("ESP_UI")
	if not bill then
		bill = Instance.new("BillboardGui")
		bill.Name = "ESP_UI"
		bill.AlwaysOnTop = true
		bill.Size = UDim2.new(0, 140, 0, 30)
		bill.StudsOffset = Vector3.new(0, 2.5, 0)
		bill.Parent = head

		local lbl = Instance.new("TextLabel")
		lbl.Name = "InfoLabel"
		lbl.Size = UDim2.new(1, 0, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.TextColor3 = Color3.new(1, 1, 1)
		lbl.TextSize = 13
		lbl.Font = Enum.Font.SourceSansBold
		lbl.TextStrokeTransparency = 0
		lbl.Parent = bill
	end

	local status = (hum and hum.Health > 0) and (math.floor(hum.Health) .. " HP") or "DEAD"
	local label = bill:FindFirstChild("InfoLabel")
	if label then
		label.Text = playerObj.Name .. " [" .. status .. "]"
	end
end

local function handlePlayerHitbox(char, playerObj)
	local alive = isAliveCharacter(char)

	if not alive then
		restoreAllCandidateParts(char, originalPlayerSizes)
		destroyESP(char)
		return
	end

	if config.GlobalHitboxToggle and config.HitboxEnabled and (not config.TeamCheck or playerObj.Team ~= LocalPlayer.Team) then
		pcall(function()
			for _, partName in ipairs(candidateParts) do
				local targetPart = char:FindFirstChild(partName)
				if targetPart then
					savePartState(char, targetPart, originalPlayerSizes)
					
					-- Only expand Head size visually, keep HumanoidRootPart hidden
					if partName == "Head" then
						targetPart.Size = Vector3.new(config.HitboxSize, config.HitboxSize, config.HitboxSize)
						targetPart.Transparency = config.HitboxTransparency
					elseif partName == "HumanoidRootPart" then
						-- Expand hitbox but keep transparency at 1 to hide it
						targetPart.Size = Vector3.new(config.HitboxSize * 1.2, config.HitboxSize * 1.2, config.HitboxSize * 1.2)
						targetPart.Transparency = 1
					end
					
					targetPart.CanCollide = false
					targetPart.Massless = true
					targetPart.CanTouch = true
				end
			end
		end)
	else
		restoreAllCandidateParts(char, originalPlayerSizes)
	end
end

local function handleNPCHitbox(char)
	if char == LocalPlayer.Character then
		return
	end

	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then
		restoreAllCandidateParts(char, originalNPCSizes)
		return
	end

	if config.GlobalHitboxToggle and config.NPCHitboxEnabled then
		pcall(function()
			for _, partName in ipairs(candidateParts) do
				local targetPart = char:FindFirstChild(partName)
				if targetPart then
					savePartState(char, targetPart, originalNPCSizes)
					
					if partName == "Head" then
						targetPart.Size = Vector3.new(config.NPCHitboxSize, config.NPCHitboxSize, config.NPCHitboxSize)
						targetPart.Transparency = config.NPCHitboxTransparency
					elseif partName == "HumanoidRootPart" then
						targetPart.Size = Vector3.new(config.NPCHitboxSize * 1.2, config.NPCHitboxSize * 1.2, config.NPCHitboxSize * 1.2)
						targetPart.Transparency = 1
					end
					
					targetPart.CanCollide = false
					targetPart.Massless = true
					targetPart.CanTouch = true
				end
			end
		end)
	else
		restoreAllCandidateParts(char, originalNPCSizes)
	end
end

local function updateNPCCache()
	local currentNPCs = {}

	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("Humanoid") then
			local model = desc.Parent
			if model and model:IsA("Model") and model ~= LocalPlayer.Character and not Players:GetPlayerFromCharacter(model) then
				table.insert(currentNPCs, model)
			end
		end
	end

	cachedNPCs = currentNPCs
end

local function refreshAllPlayers()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			updateESP(p.Character, p)
			handlePlayerHitbox(p.Character, p)
		end
	end
end

local function refreshAllNPCs()
	updateNPCCache()
	for i = 1, #cachedNPCs do
		local npc = cachedNPCs[i]
		if npc and npc.Parent then
			handleNPCHitbox(npc)
		end
	end
end
